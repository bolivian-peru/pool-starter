{
  "name": "proxy-reseller-kit",
  "private": true,
  "description": "Open-source reseller toolkit for the Proxies.sx Pool Gateway — SDK, drop-in React component, and Next.js starter template. Build a branded mobile-proxy reseller business in hours.",
  "repository": {
    "type": "git",
    "url": "https://github.com/bolivian-peru/proxy-reseller-kit"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "license": "MIT"
}
