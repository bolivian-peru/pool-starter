# =========================================================================
# Proxies.sx Pool Portal — environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# =========================================================================

# ---------- Database (self-hosted Postgres) ----------
# Format: postgres://user:password@host:port/database
# With docker-compose the default is:
DATABASE_URL=postgres://pool:pool@localhost:5432/pool_portal

# ---------- NextAuth ----------
# The canonical URL of your deployment. Use http://localhost:3000 in dev.
AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME_with_openssl_rand_base64_32
# Trust the AUTH_URL host header (set true for non-Vercel self-host)
AUTH_TRUST_HOST=true

# ---------- Email (for magic-link login) ----------
# Any SMTP server works. For local dev, leave these unset — the app prints the
# login link to the server console instead of emailing it.
#
# Examples:
#   Resend:   EMAIL_SERVER_HOST=smtp.resend.com  EMAIL_SERVER_USER=resend  EMAIL_SERVER_PASSWORD=re_...
#   Postmark: EMAIL_SERVER_HOST=smtp.postmarkapp.com  ...
#   Your own postfix:  EMAIL_SERVER_HOST=smtp.example.com  EMAIL_SERVER_PORT=587  ...
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# ---------- Proxies.sx reseller API ----------
# Mint at https://client.proxies.sx/api-keys with scope `customers:write`.
PROXIES_SX_API_KEY=psx_REPLACE_ME
# Your reseller proxyUsername (shown in Account settings). Format: psx_xxxxxxxx
PROXIES_SX_USERNAME=psx_REPLACE_ME

# ---------- Stripe ----------
# Server-side key: sk_live_... in prod, sk_test_... in dev.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook signing secret — from the Stripe dashboard, "Developers → Webhooks".
# For local dev, run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# which prints a whsec_... to use here.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Public key for browser-side (optional; not required for checkout redirect).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
